# AI Pulse Dashboard — Environment Variables
# Copy this file to .env and fill in your credentials.

# ── Reddit API (Required for Reddit sources) ──────────────────────────────────
# Register a "script" type app at: https://www.reddit.com/prefs/apps
# Redirect URI: http://localhost:8080 (required by form, not actually used)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here

# ── Supabase (Phase 5 — Leave blank for now) ──────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
